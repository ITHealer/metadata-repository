# Copy this file to .env for local overrides. Never commit .env.
GENERATOR_MODE=mock
METADATA_LOG_LEVEL=INFO

# Scheduled schema synchronization. The daily cron and self-hosted runner label remain in workflow
# YAML; local/CI processes share this independent runtime gate.
# Scheduled profiles resolve their read-only DSN through the env name in database.yml.
SCHEMA_SYNC_ENABLED=false
# TBLS_DSN_EXAMPLE=clickhouse://readonly-user:password@clickhouse.internal:9000/database

# Telegram operator notifications. Keep disabled until all three GitHub secrets are provisioned.
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_TIMEOUT_SECONDS=5
TELEGRAM_MAX_RETRIES=2

# OpenAI-compatible LiteLLM gateway. Required only when GENERATOR_MODE=live.
# OPENAI_MODEL is a gateway alias; changing its Bedrock mapping does not require a code change.
OPENAI_BASE_URL=https://ai-gateway.dev/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_RESPONSE_FORMAT=json_schema
OPENAI_PROMPT_VERSION=workflow-neutral-narrative-v2

# Local ClickHouse demo fixture
CLICKHOUSE_DB=commerce_demo
CLICKHOUSE_USER=demo
CLICKHOUSE_PASSWORD=demo_password
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# tbls receives its credential-bearing DSN from Docker Compose; only its output path is configurable.
TBLS_DOC_PATH=catalog/commerce_demo/generated/raw
